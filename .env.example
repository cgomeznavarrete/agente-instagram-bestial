# ============================================================
# AGENTE INSTAGRAM — SALSAS BESTIAL
# Copia este archivo como .env y completa los valores reales
# NUNCA subas .env al repositorio
# ============================================================

# ── Anthropic / Claude ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-aqui-va-tu-clave

# ── Instagram / Meta ─────────────────────────────────────────
# Token de larga duración (60 días). Renovar antes de que expire.
INSTAGRAM_ACCESS_TOKEN=EAAG...token-aqui
INSTAGRAM_BUSINESS_ACCOUNT_ID=17841...id-aqui
FACEBOOK_APP_ID=123456...app-id-aqui
FACEBOOK_APP_SECRET=abc123...secret-aqui

# ── Cloudinary (hosting de videos para Reels/Stories) ────────
# Obtener en: https://cloudinary.com → Dashboard → API Keys
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ── imgbb (hosting de imágenes para Posts/Carruseles) ────────
# Obtener en: https://api.imgbb.com/ → gratis
IMGBB_API_KEY=tu-clave-imgbb-aqui

# ── remove.bg (extracción de fondo del producto) ─────────────
# Obtener en: https://www.remove.bg/api → 50 créditos gratis/mes
REMOVEBG_API_KEY=tu-clave-removebg-aqui

# ── Fal.ai (generación de fondos con IA) ─────────────────────
# Obtener en: https://fal.ai → Dashboard → API Keys
FALAI_API_KEY=tu-clave-falai-aqui

# ── Configuración del agente ─────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
POSTS_POR_SEMANA=3
REELS_POR_SEMANA=2
STORIES_POR_SEMANA=5
CARRUSELES_POR_SEMANA=1
LOG_LEVEL=INFO

# ── Obsidian (bóveda nueva dedicada) ─────────────────────────
# Ruta a la bóveda Obsidian-Instagram-Bestial (separada de la existente)
OBSIDIAN_VAULT_PATH=D:/20210729/cgome/Documents/Claude/Obsidian-Instagram-Bestial
